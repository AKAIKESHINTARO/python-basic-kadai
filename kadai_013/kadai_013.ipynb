        "def calc_total_with_tax(price: float, tax_rate_percent: float) -> float:\n",
        "    return price * (1 + tax_rate_percent / 100)\n",
        "\n",
        "result = calc_total_with_tax(110, 10)\n",
        "\n",
        "print(result)"
